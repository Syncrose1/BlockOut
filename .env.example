# BlockOut Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains secrets!

# ============================================
# DROPBOX OAUTH CONFIGURATION
# ============================================
# To enable Dropbox sync, you need to create a Dropbox app:
# 1. Go to https://www.dropbox.com/developers/apps
# 2. Click "Create app"
# 3. Choose "Scoped access"
# 4. Choose "App folder" (recommended) or "Full Dropbox"
# 5. Give your app a name (e.g., "BlockOut-YourName")
# 6. Under Permissions, check:
#    - files.content.write
#    - files.content.read
# 7. Click "Submit" to apply for permissions
# 8. Go to Settings tab
# 9. Under "OAuth 2", click "Generate" next to "App key"
# 10. Add http://localhost:5173 to "Redirect URIs"
# 11. Copy the App key below

# Your Dropbox App Key (NOT the secret!)
VITE_DROPBOX_APP_KEY=your_app_key_here

# ============================================
# SUPABASE AUTH (for BlockOut Cloud sync)
# ============================================
# Create a free Supabase project at https://supabase.com
# Then go to Project Settings → API to find these values.
# These are PUBLIC keys — safe to include in the frontend bundle.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only: used to verify JWTs (optional — anon key works as fallback)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# CLOUDFLARE R2 STORAGE (server-side only)
# ============================================
# Create an R2 bucket in your Cloudflare dashboard:
# 1. Go to https://dash.cloudflare.com → R2
# 2. Create a bucket named "blockout" (or your preferred name)
# 3. Go to R2 → Manage R2 API Tokens → Create API Token
# 4. Grant "Object Read & Write" permission for the bucket

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=blockout

# ============================================
# OPTIONAL: Self-hosted server
# ============================================
# If you're using your own server instead of Dropbox:
BLOCKOUT_SERVER_URL=https://your-server.com
BLOCKOUT_SERVER_TOKEN=your_server_token

# ============================================
# DEVELOPMENT
# ============================================
# Local development port
PORT=5173

# Node environment
NODE_ENV=development
